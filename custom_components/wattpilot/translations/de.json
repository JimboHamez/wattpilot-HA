        "set_debug_properties": {
            "name": "Debug-Eigenschaften festlegen",
            "description": "Aktiviert oder deaktiviert das Protokollieren von Eigenschaftsänderungen der Ladestation als Warnungen im Log.",
            "fields": {
                "device_id": {
                    "name": "Ladestation",
                    "description": "Ladestation, auf die die Änderung angewendet wird."
                },
                "debug_properties": {
                    "name": "Debug-Eigenschaften",
                    "description": "TRUE protokolliert alle Eigenschaftsänderungen, FALSE keine, oder gib eine Liste von Eigenschafts-Codes an, um nur diese zu protokollieren."
