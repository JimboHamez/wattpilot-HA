{
    "config": {
        "flow_title": "{name}",
        "step": {
            "connection": {
                "title": "Wattpilot Ladestation",
                "description": "Wähle aus, wie Home Assistant sich mit deiner Wattpilot Ladestation verbinden soll.",
                "data": {
                    "connection": "Verbindungsart"
                },
                "data_description": {
                    "connection": "Lokal verbindet direkt über dein LAN. Cloud verbindet über die go-e Cloud anhand der Seriennummer der Ladestation."
                }
            },
            "local": {
                "title": "Lokale Verbindung",
                "description": "Gib die lokalen Netzwerkdaten deiner Wattpilot Ladestation ein.",
                "data": {
                    "friendly_name": "Name",
                    "ip_address": "IP-Adresse",
                    "password": "Passwort",
                    "timeout": "Zeitüberschreitung"
                },
                "data_description": {
                    "friendly_name": "Anzeigename der Ladestation in Home Assistant.",
                    "ip_address": "Lokale IP-Adresse der Ladestation in deinem Netzwerk.",
                    "password": "Das in der Wattpilot-App festgelegte lokale Passwort der Ladestation.",
                    "timeout": "Sekunden, die auf den Verbindungsaufbau und die Initialisierung gewartet wird."
                }
            },
            "cloud": {
                "title": "Cloud-Verbindung",
                "description": "Gib die go-e Cloud-Daten deiner Wattpilot Ladestation ein.",
                "data": {
                    "friendly_name": "Name",
                    "serial": "Seriennummer",
                    "password": "Passwort",
                    "timeout": "Zeitüberschreitung"
                },
                "data_description": {
                    "friendly_name": "Anzeigename der Ladestation in Home Assistant.",
                    "serial": "Seriennummer der Ladestation, über die sie in der go-e Cloud erreicht wird.",
                    "password": "Das für deine Ladestation festgelegte Cloud-Passwort.",
                    "timeout": "Sekunden, die auf den Verbindungsaufbau und die Initialisierung gewartet wird."
                }
            },
            "zeroconf_confirm": {
                "title": "Wattpilot Ladestation",
                "description": "Richte die gefundene Wattpilot Ladestation „{name}“ ein.",
                "data": {
                    "password": "Passwort",
                    "timeout": "Zeitüberschreitung"
                },
                "data_description": {
                    "password": "Das in der Wattpilot-App festgelegte lokale Passwort der Ladestation.",
                    "timeout": "Sekunden, die auf den Verbindungsaufbau und die Initialisierung gewartet wird."
                }
            },
            "reauth_confirm": {
                "title": "Wattpilot Ladestation",
                "description": "Das Passwort für „{name}“ ist nicht mehr gültig. Gib das aktuelle Passwort der Ladestation ein.",
                "data": {
                    "password": "Passwort"
                },
                "data_description": {
                    "password": "Das in der Wattpilot-App festgelegte lokale Passwort der Ladestation."
                }
            }
        },
        "abort": {
            "already_configured": "Diese Ladestation ist bereits konfiguriert.",
            "exception": "Ein unerwarteter Fehler ist aufgetreten. Bitte prüfe die Logdateien für Details.",
            "no_serial": "Das gefundene Gerät hat keine Seriennummer bereitgestellt.",
            "reauth_successful": "Die erneute Authentifizierung war erfolgreich."
