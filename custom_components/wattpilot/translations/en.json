{
    "config": {
        "flow_title": "{name}",
        "step": {
            "connection": {
                "title": "Wattpilot charger",
                "description": "Choose how Home Assistant should connect to your Wattpilot charger.",
                "data": {
                    "connection": "Connection type"
                },
                "data_description": {
                    "connection": "Local connects directly over your LAN. Cloud connects through the go-e cloud using the charger serial number."
                }
            },
            "local": {
                "title": "Local connection",
                "description": "Enter the local network details of your Wattpilot charger.",
                "data": {
                    "friendly_name": "Name",
                    "ip_address": "IP address",
                    "password": "Password",
                    "timeout": "Timeout"
                },
                "data_description": {
                    "friendly_name": "Display name for the charger in Home Assistant.",
                    "ip_address": "Local IP address of the charger on your network.",
                    "password": "The local charger password configured in the Wattpilot app.",
                    "timeout": "Seconds to wait for the connection to be established and initialised."
                }
            },
            "cloud": {
                "title": "Cloud connection",
                "description": "Enter the go-e cloud details of your Wattpilot charger.",
                "data": {
                    "friendly_name": "Name",
                    "serial": "Serial number",
                    "password": "Password",
                    "timeout": "Timeout"
                },
                "data_description": {
                    "friendly_name": "Display name for the charger in Home Assistant.",
                    "serial": "Serial number of the charger, used to reach it through the go-e cloud.",
                    "password": "The cloud password configured for your charger.",
                    "timeout": "Seconds to wait for the connection to be established and initialised."
                }
            },
            "zeroconf_confirm": {
                "title": "Wattpilot charger",
                "description": "Set up the discovered Wattpilot charger \"{name}\".",
                "data": {
                    "password": "Password",
                    "timeout": "Timeout"
                },
                "data_description": {
                    "password": "The local charger password configured in the Wattpilot app.",
                    "timeout": "Seconds to wait for the connection to be established and initialised."
                }
            },
            "reauth_confirm": {
                "title": "Wattpilot charger",
                "description": "The password for \"{name}\" is no longer valid. Enter the current charger password.",
                "data": {
                    "password": "Password"
                },
                "data_description": {
                    "password": "The local charger password configured in the Wattpilot app."
                }
            }
        },
        "abort": {
            "already_configured": "This charger is already configured.",
            "exception": "An unexpected error occurred. Please check the logs for details.",
            "no_serial": "The discovered device did not advertise a serial number.",
            "reauth_successful": "Reauthentication was successful."
        },
        "error": {
            "invalid_auth": "Invalid password. Please check the charger password and try again.",
            "cannot_connect": "Failed to connect to the charger. Please check it is online and try again."
        }
    },
    "options": {
        "step": {
            "config_connection": {
                "title": "Wattpilot charger",
