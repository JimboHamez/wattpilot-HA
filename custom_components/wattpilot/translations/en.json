    "selector": {
        "connection": {
            "options": {
                "local": "Local (LAN)",
                "cloud": "go-e Cloud"
            }
        }
    },
    "services": {
        "set_next_trip": {
            "name": "Set next trip",
            "description": "Sets the departure time used by the Next Trip charging mode.",
            "fields": {
                "device_id": {
                    "name": "Charger",
                    "description": "Charger device to apply the change to."
                },
                "trigger_time": {
                    "name": "Next trip",
                    "description": "Time of the next trip departure."
                }
            }
        },
        "set_goe_cloud": {
            "name": "Set go-e cloud",
            "description": "Enables or disables go-e cloud access for the charger.",
            "fields": {
                "device_id": {
                    "name": "Charger",
                    "description": "Charger device to apply the change to."
                },
                "cloud_api": {
                    "name": "Cloud API",
                    "description": "Turn go-e cloud API access on or off."
                }
            }
        },
        "set_debug_properties": {
            "name": "Set debug properties",
            "description": "Enables or disables logging of charger property changes as warnings in the log.",
            "fields": {
                "device_id": {
                    "name": "Charger",
                    "description": "Charger device to apply the change to."
                },
                "debug_properties": {
                    "name": "Debug properties",
                    "description": "TRUE logs all property changes, FALSE logs none, or provide a list of property codes to log only those."
                }
            }
        },
        "disconnect_charger": {
            "name": "Disconnect charger",
            "description": "Disconnects an established charger connection. Entities become unavailable until reconnected.",
            "fields": {
                "device_id": {
                    "name": "Charger",
                    "description": "Charger device to apply the change to."
                }
            }
        },
        "reconnect_charger": {
            "name": "Reconnect charger",
            "description": "Re-establishes a disconnected charger connection.",
            "fields": {
                "device_id": {
                    "name": "Charger",
                    "description": "Charger device to apply the change to."
                }
            }
        }
    },
